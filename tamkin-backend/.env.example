APP_NAME="Tamkin"

NODE_ENV="development"

# ===================== Localhost Ports =====================

BACKEND_PORT="3000"
FRONTEND_PORT="3200"
BASE_URL="http://localhost:3000"

# ===================== Database Config =====================

DATABASE_HOST="localhost"
DATABASE_PORT="5432"
DATABASE_USER="your_database_user"
DATABASE_PASSWORD="your_database_password"
DATABASE_NAME="tamkin_db"

# ===================== Google OAuth =====================

GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ===================== Encryption Key =====================

CRYPTO_KEY="your_crypto_key"

# ===================== Hashing =====================

HASH_SALT="12"
EMAIL_HASH_SECRET="your_email_hash_secret"
TOKEN_HASH_SECRET="your_token_hash_secret"

# ===================== JWT Secrets - Super Admin =====================

SUPER_ADMIN_ACCESS_TOKEN_SECRET="your_super_admin_access_secret"
SUPER_ADMIN_REFRESH_TOKEN_SECRET="your_super_admin_refresh_secret"

# ===================== JWT Secrets - Admin =====================

ADMIN_ACCESS_TOKEN_SECRET="your_admin_access_secret"
ADMIN_REFRESH_TOKEN_SECRET="your_admin_refresh_secret"

# ===================== JWT Secrets - User =====================

USER_ACCESS_TOKEN_SECRET="your_user_access_secret"
USER_REFRESH_TOKEN_SECRET="your_user_refresh_secret"

# ===================== Access Token Config =====================

ACCESS_TOKEN_EXPIRES="1h"
ACCESS_TOKEN_EXPIRES_DEV_MOOD="1d"

ACCESS_TOKEN_IN_COOKIES="3600000"
ACCESS_TOKEN_IN_COOKIES_DEV_MOOD="86400000"

# ===================== Refresh Token Config =====================

REFRESH_TOKEN_EXPIRES="7d"
REFRESH_TOKEN_IN_COOKIES="604800000"

# ===================== Email Config =====================

APP_EMAIL="your_app_email"
APP_PASSWORD="your_app_password"
EMAIL_PORT="587"